TELEGRAM_BOT_TOKEN=
TELEGRAM_PROXY=
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
APP_TIMEZONE=Europe/Berlin

# AI provider: "gigachat" | "yandex" | "openai" | "mock"
AI_PROVIDER=gigachat

# GigaChat (Sber) — recommended: text + vision in one API
# Get credentials at: https://developers.sber.ru/
# Format: "client_id:client_secret" (will be base64-encoded automatically)
GIGACHAT_CREDENTIALS=
GIGACHAT_MODEL=GigaChat-2-Max

# YandexGPT (legacy, text-only)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt-5.1

# OpenAI-compatible (GPT-4o, Gemini via OpenRouter, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
